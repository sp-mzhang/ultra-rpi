{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "UltraConfigBucketList",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:ListBucketVersions"],
      "Resource": "arn:aws:s3:::siphox-ultra-config"
    },
    {
      "Sid": "UltraConfigObjectsRW",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObjectVersion",
        "s3:ListObjectVersions"
      ],
      "Resource": "arn:aws:s3:::siphox-ultra-config/*"
    }
  ]
}
